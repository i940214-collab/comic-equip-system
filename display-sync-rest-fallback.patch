     cloudWriteChainRef.current = cloudWriteChainRef.current
       .catch(() => null)
       .then(() => setDoc(stateDoc, payload, { merge: true }))
-      .catch((error) => console.error("Update error:", error));
+      .catch(writeStateRestFallback);
     return cloudWriteChainRef.current;
   };
 
