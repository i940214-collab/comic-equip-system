           addAssetDocument(db, appId, {
             name: assetName,
             url: assetUrl,
@@ -2479,6 +2506,7 @@ function AssetLibraryModal({ assets, setAssets, db, storage, appId, localMode, o
           12000,
           '素材寫入逾時，請稍後再試。'
