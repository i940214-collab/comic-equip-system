@@ -2466,7 +2493,7 @@ function AssetLibraryModal({ assets, setAssets, db, storage, appId, localMode, o
           patchUploadItem(itemId, { progress: 86, message: '寫入雲端中...' });
         }
 
-        await runWithTimeout(
